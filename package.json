{
  "name": "aiusd-skill",
  "version": "2.0.0",
  "description": "AIUSD trading and account management skill via MCP protocol. ",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "npm run build && node dist/index.js test",
    "clean": "rm -rf dist node_modules package-lock.json",
    "install-deps": "npm install",
    "package": "npm run build && npm pack",
    "build-skill": "node scripts/build-skill.js",
    "build-installers": "node scripts/build-js-installer.js && node scripts/build-sh-installer.js",
    "publish-cli": "cd packages/aiusd-skills && npm publish",
    "setup": "node scripts/skill-init.js",
    "login": "node dist/index.js login",
    "postinstall": "node scripts/skill-init.js"
  },
  "bin": {
    "aiusd": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md",
    "SKILL.md",
    "skills/",
    "scripts/",
    "package.json",
    "tsconfig.json"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.0",
    "commander": "^12.0.0",
    "ethers": "^6.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "aiusd",
    "trading",
    "skill",
    "typescript",
    "blockchain",
    "defi"
  ],
  "author": "AIUSD Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/galpha-ai/aiusd-skills.git"
  },
  "homepage": "https://github.com/galpha-ai/aiusd-skills#readme",
  "bugs": {
    "url": "https://github.com/galpha-ai/aiusd-skills/issues"
  }
}
